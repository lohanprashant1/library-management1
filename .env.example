# ─── Database ──────────────────────────────────────────────────────────
# For local development (SQLite file):
DATABASE_URL="file:./db/custom.db"

# For Turso (cloud SQLite) - use on Vercel/Netlify:
# DATABASE_URL="libsql://your-db-name-your-org.turso.io"
# TURSO_AUTH_TOKEN="your-turso-auth-token"

# ─── App ──────────────────────────────────────────────────────────────
# Optional: Custom app URL (auto-detected on most platforms)
NEXTAUTH_URL="http://localhost:3000"
# Optional: Secret for sessions (generate with: openssl rand -base64 32)
NEXTAUTH_SECRET=""

# ─── Node Environment ────────────────────────────────────────────────
NODE_ENV="development"
